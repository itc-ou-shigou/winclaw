{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": { "description": "Standalone Azure Cache for Redis." },
  "parameters": {
    "projectName": { "type": "string" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "redisSku": { "type": "string", "defaultValue": "Standard", "allowedValues": ["Basic", "Standard", "Premium"] },
    "redisCapacity": { "type": "int", "defaultValue": 1, "allowedValues": [0, 1, 2, 3, 4, 5, 6] }
  },
  "variables": {
    "redisName": "[format('{0}-redis', parameters('projectName'))]",
    "family": "[if(equals(parameters('redisSku'), 'Premium'), 'P', 'C')]"
  },
  "resources": [
    {
      "type": "Microsoft.Cache/redis",
      "apiVersion": "2023-08-01",
      "name": "[variables('redisName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "[parameters('redisSku')]",
          "family": "[variables('family')]",
          "capacity": "[parameters('redisCapacity')]"
        },
        "enableNonSslPort": false,
        "minimumTlsVersion": "1.2",
        "redisConfiguration": {
          "maxmemory-policy": "allkeys-lru"
        }
      }
    }
  ],
  "outputs": {
    "redisHost": {
      "type": "string",
      "value": "[format('{0}.redis.cache.windows.net', variables('redisName'))]"
    },
    "redisSslPort": {
      "type": "int",
      "value": 6380
    }
  }
}
