{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": { "description": "Standalone Azure Database Flexible Server (MySQL or PostgreSQL) with firewall rules." },
  "parameters": {
    "projectName": { "type": "string" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "dbEngine": { "type": "string", "defaultValue": "mysql", "allowedValues": ["mysql", "postgresql"] },
    "dbSku": { "type": "string", "defaultValue": "Standard_B1ms" },
    "dbVersion": { "type": "string", "defaultValue": "8.0.21" },
    "dbStorageGB": { "type": "int", "defaultValue": 20 },
    "dbAdminUser": { "type": "string", "defaultValue": "dbadmin" },
    "dbAdminPassword": { "type": "securestring" },
    "haMode": { "type": "string", "defaultValue": "Disabled", "allowedValues": ["Disabled", "SameZone", "ZoneRedundant"] }
  },
  "variables": {
    "dbServerName": "[format('{0}-db', parameters('projectName'))]",
    "dbTier": "[if(startsWith(parameters('dbSku'), 'Standard_B'), 'Burstable', if(startsWith(parameters('dbSku'), 'Standard_E'), 'MemoryOptimized', 'GeneralPurpose'))]"
  },
  "resources": [
    {
      "condition": "[equals(parameters('dbEngine'), 'mysql')]",
      "type": "Microsoft.DBforMySQL/flexibleServers",
      "apiVersion": "2023-06-30",
      "name": "[variables('dbServerName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "[parameters('dbSku')]", "tier": "[variables('dbTier')]" },
      "properties": {
        "version": "[parameters('dbVersion')]",
        "administratorLogin": "[parameters('dbAdminUser')]",
        "administratorLoginPassword": "[parameters('dbAdminPassword')]",
        "storage": { "storageSizeGB": "[parameters('dbStorageGB')]" },
        "backup": { "backupRetentionDays": 7, "geoRedundantBackup": "Disabled" },
        "highAvailability": { "mode": "[parameters('haMode')]" }
      }
    },
    {
      "condition": "[equals(parameters('dbEngine'), 'mysql')]",
      "type": "Microsoft.DBforMySQL/flexibleServers/firewallRules",
      "apiVersion": "2023-06-30",
      "name": "[format('{0}/AllowAzureServices', variables('dbServerName'))]",
      "dependsOn": ["[resourceId('Microsoft.DBforMySQL/flexibleServers', variables('dbServerName'))]"],
      "properties": { "startIpAddress": "0.0.0.0", "endIpAddress": "0.0.0.0" }
    },
    {
      "condition": "[equals(parameters('dbEngine'), 'postgresql')]",
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-06-01-preview",
      "name": "[variables('dbServerName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "[parameters('dbSku')]", "tier": "[variables('dbTier')]" },
      "properties": {
        "version": "[parameters('dbVersion')]",
        "administratorLogin": "[parameters('dbAdminUser')]",
        "administratorLoginPassword": "[parameters('dbAdminPassword')]",
        "storage": { "storageSizeGB": "[parameters('dbStorageGB')]" },
        "backup": { "backupRetentionDays": 7, "geoRedundantBackup": "Disabled" },
        "highAvailability": { "mode": "[parameters('haMode')]" }
      }
    },
    {
      "condition": "[equals(parameters('dbEngine'), 'postgresql')]",
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/AllowAzureServices', variables('dbServerName'))]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('dbServerName'))]"],
      "properties": { "startIpAddress": "0.0.0.0", "endIpAddress": "0.0.0.0" }
    }
  ],
  "outputs": {
    "dbFqdn": {
      "type": "string",
      "value": "[format('{0}.{1}.database.azure.com', variables('dbServerName'), parameters('dbEngine'))]"
    },
    "dbPort": {
      "type": "string",
      "value": "[if(equals(parameters('dbEngine'), 'mysql'), '3306', '5432')]"
    }
  }
}
