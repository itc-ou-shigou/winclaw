# =============================================================================
# WinClaw Node Image — Lightweight gateway-only container
#
# Minimal image for running a winclaw gateway node that connects to a GRC
# server. Designed for easy deployment with environment variables.
#
# Build (multi-arch linux/amd64 + linux/arm64):
#   docker buildx build --platform linux/amd64,linux/arm64 \
#     -t itccloudsoft/winclaw-node:latest \
#     -f docker/Dockerfile.node --push .
#
# Run:
#   docker run -p 18789:18789 \
#     -e WINCLAW_GRC_URL=http://localhost:3100 \
#     -e employee_name=橋本透 \
#     -e employee_code=0753242 \
#     itccloudsoft/winclaw-node:latest
#
# Access chat UI:
#   http://localhost:18789/chat
# =============================================================================
FROM node:22-bookworm-slim

LABEL org.opencontainers.image.title="WinClaw Node" \
  org.opencontainers.image.description="Lightweight winclaw gateway node for GRC-connected AI agent deployment" \
  org.opencontainers.image.source="https://github.com/user/winclaw" \
  org.opencontainers.image.licenses="MIT" \
  org.opencontainers.image.vendor="ITC CloudSoft"

ENV DEBIAN_FRONTEND=noninteractive

# ---------------------------------------------------------------------------
# Layer 1: Minimal system packages
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    jq \
    tini \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Layer 2: Install winclaw from pre-built tgz
# ---------------------------------------------------------------------------
COPY docker/winclaw-2026.3.15.tgz /tmp/winclaw.tgz
RUN npm install -g /tmp/winclaw.tgz && rm -f /tmp/winclaw.tgz

# ---------------------------------------------------------------------------
# Layer 3: Create non-root user
# ---------------------------------------------------------------------------
RUN useradd -m -s /bin/bash winclaw \
  && mkdir -p /home/winclaw/.winclaw \
  && chown -R winclaw:winclaw /home/winclaw

# ---------------------------------------------------------------------------
# Layer 4: Copy entrypoint script
# ---------------------------------------------------------------------------
COPY docker/entrypoint-node.sh /usr/local/bin/entrypoint-node.sh
RUN sed -i "s/\r$//" /usr/local/bin/entrypoint-node.sh && chmod +x /usr/local/bin/entrypoint-node.sh

# ---------------------------------------------------------------------------
# Environment defaults (overridable at runtime via -e)
# ---------------------------------------------------------------------------
ENV WINCLAW_GRC_URL="https://grc.myaiportal.net" \
    employee_name="" \
    employee_code="" \
    WINCLAW_GATEWAY_PORT="18789" \
    WINCLAW_GATEWAY_BIND="lan" \
    WINCLAW_GATEWAY_AUTH="token"

# ---------------------------------------------------------------------------
# Switch to non-root user
# ---------------------------------------------------------------------------
USER winclaw
WORKDIR /home/winclaw

# ---------------------------------------------------------------------------
# Expose gateway port
# ---------------------------------------------------------------------------
EXPOSE 18789

# ---------------------------------------------------------------------------
# Health check
# ---------------------------------------------------------------------------
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:18789/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

# ---------------------------------------------------------------------------
# Use tini as PID 1 for proper signal handling
# ---------------------------------------------------------------------------
ENTRYPOINT ["tini", "--", "/usr/local/bin/entrypoint-node.sh"]
